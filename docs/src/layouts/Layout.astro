---
const { frontmatter } = Astro.props;
const title =
	Astro.props.title ||
	frontmatter?.title ||
	"RawBack - One-click from raw files back to repository context";
const lang = Astro.props.lang || frontmatter?.lang || "en";
const isDoc = Astro.props.isDoc || frontmatter?.isDoc || false;
const base = import.meta.env.BASE_URL;
const root = base.replace(/\/$/, "");
const homeHref = lang === "zh" ? `${root}/zh/` : `${root}/`;
const anchorBase = lang === "zh" ? `${root}/zh/` : `${root}/`;

const currentPath = Astro.url.pathname;
let enHref = `${root}/`;
let zhHref = `${root}/zh/`;

if (lang === "zh") {
	if (currentPath.includes(`${root}/zh/`)) {
		enHref = currentPath.replace(`${root}/zh/`, `${root}/`);
	} else if (currentPath.endsWith("/zh")) {
		enHref = currentPath.slice(0, -3) || "/";
	}
} else {
	if (currentPath.startsWith(`${root}/`)) {
		if (currentPath === root || currentPath === `${root}/`) {
			zhHref = `${root}/zh/`;
		} else {
			zhHref = currentPath.replace(`${root}/`, `${root}/zh/`);
		}
	}
}
---

<!doctype html>
<html lang={lang === "zh" ? "zh-Hans" : "en"}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta
			name="description"
			content="A lightweight browser extension to return to the full repository context from any raw Git file view in a single click."
		/>
		<meta name="theme-color" content="#fbfcfb" />
		<link rel="icon" type="image/png" href={`${base}/icon.png`} />
		<title>{title}</title>
		<script is:inline define:vars={{ base }}>
			try {
				const userLangPref = localStorage.getItem("rawback-lang-pref");
				if (!userLangPref) {
					const sysLang = navigator.language || navigator.userLanguage;
					const isZh = sysLang && sysLang.toLowerCase().startsWith("zh");
					const baseNormalized = base.replace(/\/$/, "");
					const currentPath = window.location.pathname.replace(/\/$/, "");

					if (
						isZh &&
						(currentPath === baseNormalized ||
							currentPath === "" ||
							currentPath === "/")
					) {
						window.location.href = baseNormalized + "/zh/";
					}
				}
			} catch (e) {
				console.error("Language detection error:", e);
			}
		</script>
	</head>
	<body>
		<header class="site-header">
			<div class="site-header-inner">
				<a class="brand" href={homeHref} aria-label="RawBack home">
					<img src={`${base}/assets/rawback-icon.png`} alt="" />
					<span>RawBack</span>
				</a>

				<nav class="nav-actions" aria-label={lang === "zh" ? "页面导航" : "Page navigation"}>
					{
						lang === "zh" ? (
							<>
								<a class="nav-link" href={`${anchorBase}#features`}>
									功能特性
								</a>
								<a class="nav-link" href={`${anchorBase}guide`}>
									常见问题
								</a>
							</>
						) : (
							<>
								<a class="nav-link" href={`${anchorBase}#features`}>
									Features
								</a>
								<a class="nav-link" href={`${anchorBase}guide`}>
									Guide
								</a>
							</>
						)
					}
					<a
						class="nav-button"
						href="https://github.com/tuot/RawBack"
						target="_blank"
						rel="noopener">GitHub</a
					>
					<a class="nav-button nav-button-primary" href={`${anchorBase}#install`}>
						{lang === "zh" ? "立即安装" : "Install"}
					</a>
				</nav>
			</div>
		</header>

		{
			isDoc ? (
				<main class="markdown-body">
					<slot />
				</main>
			) : (
				<slot />
			)
		}

		<footer class="site-footer">
			<span>© 2026 RawBack. All rights reserved.</span>
			<div class="footer-meta">
				<nav aria-label={lang === "zh" ? "页脚链接" : "Footer links"}>
					<a href="https://github.com/tuot/RawBack" target="_blank" rel="noopener">GitHub</a>
					<a
						href="https://github.com/tuot/RawBack/blob/main/LICENSE"
						target="_blank"
						rel="noopener"
					>
						{lang === "zh" ? "开源协议 (Apache 2.0)" : "Apache 2.0 License"}
					</a>
				</nav>
				<div class="lang-links">
					<a href={enHref} class={lang === "en" ? "active" : ""} data-lang="en">EN</a>
					<span class="separator">/</span>
					<a href={zhHref} class={lang === "zh" ? "active" : ""} data-lang="zh">中文</a>
				</div>
			</div>
		</footer>

		<script is:inline>
			const langLinks = document.querySelectorAll(".lang-links a");
			langLinks.forEach(link => {
				link.addEventListener("click", () => {
					const langVal = link.getAttribute("data-lang");
					try {
						localStorage.setItem("rawback-lang-pref", langVal);
					} catch (err) {
						console.error("Failed to save language preference:", err);
					}
				});
			});
		</script>
	</body>
</html>

<style is:global>
	:root {
		color-scheme: light;
		--paper: #fbfcfb;
		--surface: #ffffff;
		--ink: #111315;
		--ink-soft: #3f464d;
		--muted: #717982;
		--line: #dde1e5;
		--green: #2ea35d;
		--green-deep: #1f7f46;
		--green-soft: #eef7f1;
		--shadow: 0 18px 38px rgba(17, 24, 39, 0.08);
		--anchor-offset: 92px;
	}

	* {
		box-sizing: border-box;
	}

	html {
		scroll-behavior: smooth;
		scroll-padding-top: var(--anchor-offset);
	}

	[id] {
		scroll-margin-top: var(--anchor-offset);
	}

	body {
		margin: 0;
		overflow-x: hidden;
		color: var(--ink);
		background:
			radial-gradient(circle at 50% 0%, rgba(46, 163, 93, 0.08), transparent 470px),
			linear-gradient(180deg, #ffffff 0%, var(--paper) 100%);
		font-family:
			Inter,
			ui-sans-serif,
			system-ui,
			-apple-system,
			BlinkMacSystemFont,
			"Segoe UI",
			sans-serif;
	}

	a {
		color: inherit;
		transition:
			color 180ms ease,
			border-color 180ms ease,
			background-color 180ms ease,
			box-shadow 180ms ease,
			transform 180ms ease;
	}

	.site-header {
		position: sticky;
		top: 0;
		z-index: 20;
		width: 100%;
		background: rgba(255, 255, 255, 0.86);
		backdrop-filter: blur(18px);
		-webkit-backdrop-filter: blur(18px);
	}

	.site-header-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 24px;
		width: min(1120px, calc(100% - 56px));
		margin: 0 auto;
		padding: 18px 0;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		color: #111315;
		font-size: 22px;
		font-weight: 800;
		letter-spacing: 0;
		text-decoration: none;
		white-space: nowrap;
	}

	.brand img {
		width: 30px;
		height: 30px;
		border-radius: 7px;
	}

	.nav-actions {
		display: flex;
		align-items: center;
		justify-content: flex-end;
		gap: 18px;
		min-width: 0;
	}

	.nav-link {
		color: #20252a;
		font-size: 14px;
		font-weight: 600;
		line-height: 38px;
		text-decoration: none;
		white-space: nowrap;
	}

	.nav-link:hover {
		color: var(--green-deep);
	}

	.footer-meta {
		display: flex;
		align-items: center;
		gap: 32px;
	}

	.lang-links {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		font-size: 12px;
	}

	.lang-links a {
		color: #717982;
		text-decoration: none;
		font-weight: 500;
	}

	.lang-links a.active {
		color: var(--ink);
		font-weight: 700;
		pointer-events: none;
	}

	.lang-links a:not(.active):hover {
		color: var(--green-deep);
	}

	.lang-links .separator {
		color: #dde1e5;
	}

	.nav-button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 82px;
		height: 40px;
		padding: 0 18px;
		border: 1px solid var(--line);
		border-radius: 8px;
		color: #111315;
		background: #fff;
		font-size: 14px;
		font-weight: 700;
		text-decoration: none;
		white-space: nowrap;
	}

	.nav-button:hover {
		border-color: #b7c0c8;
	}

	.nav-button-primary {
		min-width: 92px;
		border-color: var(--green);
		color: #fff;
		background: var(--green);
		box-shadow: 0 10px 18px rgba(46, 163, 93, 0.18);
	}

	.nav-button-primary:hover {
		border-color: var(--green-deep);
		background: var(--green-deep);
	}

	.site-footer {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 20px;
		width: min(1120px, calc(100% - 56px));
		margin: 0 auto;
		padding: 26px 0 32px;
		color: #717982;
		font-size: 12px;
	}

	.site-footer nav {
		display: flex;
		align-items: center;
		gap: 32px;
	}

	.site-footer a {
		color: #59616a;
		text-decoration: none;
	}

	.site-footer a:hover {
		color: var(--green-deep);
	}

	.markdown-body {
		max-width: 800px;
		margin: 42px auto 0;
		padding: 0 18px 42px;
		color: var(--ink-soft);
		line-height: 1.75;
	}

	.markdown-body h1,
	.markdown-body h2,
	.markdown-body h3 {
		margin: 1.6em 0 0.65em;
		color: var(--ink);
		font-weight: 800;
		letter-spacing: 0;
	}

	.markdown-body h1 {
		font-size: 36px;
		line-height: 1.2;
		padding-bottom: 12px;
		border-bottom: 1px solid var(--line);
	}

	.markdown-body h2 {
		font-size: 26px;
		line-height: 1.25;
		padding-bottom: 8px;
		border-bottom: 1px solid var(--line);
	}

	.markdown-body h3 {
		font-size: 20px;
	}

	.markdown-body a {
		color: var(--green-deep);
		font-weight: 700;
		text-decoration-color: rgba(46, 163, 93, 0.35);
		text-underline-offset: 4px;
	}

	.markdown-body code {
		padding: 0.2em 0.4em;
		border-radius: 4px;
		background: var(--green-soft);
		color: #183926;
		font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
		font-size: 0.9em;
	}

	.markdown-body pre {
		overflow-x: auto;
		padding: 16px;
		border: 1px solid var(--line);
		border-radius: 8px;
		background: #fff;
	}

	.markdown-body pre code {
		padding: 0;
		background: none;
	}

	@media (max-width: 940px) {
		:root {
			--anchor-offset: 146px;
		}

		.site-header-inner {
			align-items: flex-start;
			flex-direction: column;
			width: min(100% - 36px, 1120px);
		}

		.nav-actions {
			justify-content: flex-start;
			flex-wrap: wrap;
			gap: 10px;
			width: 100%;
		}

		.nav-link {
			line-height: 32px;
		}

		.site-footer {
			width: min(100% - 36px, 1120px);
		}
	}

	@media (max-width: 640px) {
		:root {
			--anchor-offset: 138px;
		}

		.site-header-inner {
			width: min(100% - 28px, 1120px);
			padding: 14px 0;
		}

		.brand {
			font-size: 20px;
		}

		.nav-actions {
			gap: 8px;
		}

		.nav-link {
			font-size: 13px;
		}

		.nav-button {
			height: 34px;
			min-width: 72px;
			padding: 0 12px;
			font-size: 13px;
		}

		.site-footer {
			align-items: flex-start;
			flex-direction: column;
			width: min(100% - 28px, 1120px);
		}

		.site-footer nav {
			flex-wrap: wrap;
			gap: 16px;
		}

		.footer-meta {
			flex-direction: column;
			align-items: flex-start;
			gap: 16px;
			width: 100%;
		}
	}
</style>
