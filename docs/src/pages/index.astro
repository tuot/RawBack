---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="RawBack - Return from raw files to repository context" lang="en">
  <main class="shell">
    <section class="hero">
      <div>
        <p class="eyebrow">Safari extension and browser add-on</p>
        <h1>Raw files, back in context.</h1>
        <p class="lead">
          RawBack adds a quiet repository navigation banner to raw Git file views, so
          one click restores the branch, path, history, and project around the file.
        </p>
        <div class="actions">
          <a class="button primary" href="https://apps.apple.com/app/id6770844819" target="_blank" rel="noopener">
            <svg class="btn-icon" viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
              <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M15.97 4.17c.66-.81 1.11-1.93.99-3.06-.96.04-2.13.64-2.82 1.45-.6.7-1.13 1.84-.99 2.94.1 1.08 2.16 1.48 2.82.67z"/>
            </svg>
            <span>App Store</span>
          </a>
          <a class="button" href="https://github.com/tuot/RawBack/releases/latest" target="_blank" rel="noopener">
            <svg class="btn-icon" viewBox="0 0 98 96" width="18" height="18" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M48.854 0C21.839 0 0 22 0 49.217c0 21.756 13.993 40.172 33.4 46.68 2.447.453 3.337-.107 3.337-2.378 0-1.185-.04-4.304-.065-8.448-13.59 2.978-16.455-6.61-16.455-6.61-2.221-5.697-5.423-7.213-5.423-7.213-4.436-3.06.336-3 .336-3 4.908.348 7.493 5.093 7.493 5.093 4.359 7.537 11.442 5.358 14.228 4.096.444-3.187 1.706-5.36 3.1-6.6-10.849-1.25-22.256-5.476-22.256-24.39 0-5.389 1.905-9.8 5.03-13.257-.504-1.25-2.18-6.27.478-13.07 0 0 4.11-1.328 13.47 5.072 3.9-1.093 8.09-1.636 12.246-1.656 4.148.02 8.337.563 12.25 1.656 9.346-6.4 13.447-5.072 13.447-5.072 2.668 6.8 1.002 11.82.498 13.07 3.13 3.458 5.022 7.868 5.022 13.257 0 18.966-11.423 23.125-22.31 24.35 1.758 1.53 3.328 4.534 3.328 9.138 0 6.6-.06 11.91-.06 13.543 0 2.29.87 4.87 3.36 4.385C84.024 89.378 98 70.969 98 49.217 98 22 76.16 0 48.854 0z"/>
            </svg>
            <span>GitHub Releases</span>
          </a>
        </div>
        <p class="note">
          Works locally in your browser. No account, no ads, no analytics.
        </p>
      </div>

      <div class="hero-art" aria-label="RawBack screenshots">
        <figure class="mac-frame">
          <img
            src={`${base}/assets/rawback-mac.png`}
            alt="RawBack showing a repository navigation banner on a raw GitHub file in Safari"
          />
        </figure>
        <figure class="phone-frame">
          <img
            src={`${base}/assets/rawback-ios.png`}
            alt="RawBack settings panel on iPhone"
          />
        </figure>
        <div class="context-strip" aria-hidden="true">
          <div class="context-row">
            <span class="context-label">Raw URL</span>
            <span class="context-value">raw.githubusercontent.com/org/repo/main/file.ts</span>
          </div>
          <div class="context-row">
            <span class="context-label">Repository</span>
            <span class="context-value">github.com/org/repo/blob/main/file.ts</span>
          </div>
        </div>
      </div>
    </section>

    <section class="section" id="features">
      <div class="section-head">
        <h2>A small tool for a common detour.</h2>
        <p>
          Raw file views are useful for copying and reading, but they hide the repository
          frame. RawBack keeps that frame one click away without taking over the page.
        </p>
      </div>

      <div class="flow" aria-label="RawBack navigation flow">
        <article class="flow-card">
          <div class="flow-top">
            <span class="host"><span class="host-dot"></span>Raw file view</span>
          </div>
          <pre class="code-path">https://raw.githubusercontent.com/codecrafters-io/build-your-own-x/refs/heads/master/README.md</pre>
        </article>

        <div class="flow-arrow" aria-hidden="true">-&gt;</div>

        <article class="flow-card">
          <div class="flow-top">
            <span class="host"><span class="host-dot"></span>Repository context</span>
          </div>
          <pre class="code-path">https://github.com/codecrafters-io/build-your-own-x/blob/master/README.md</pre>
          <div class="repo-banner">
            <div>
              <strong>View in repository</strong>
              <span>Branch, path, and surrounding files are back.</span>
            </div>
            <span class="repo-pill">Open</span>
          </div>
        </article>
      </div>
    </section>

    <section class="section">
      <div class="section-head">
        <h2>Quiet where it should be.</h2>
        <p>
          The extension stays focused on navigation, preferences, and host coverage,
          with the visual weight kept out of your raw file content.
        </p>
      </div>

      <div class="feature-grid">
        <article class="feature-card">
          <div class="feature-icon" aria-hidden="true">01</div>
          <h3>Back to the repository</h3>
          <p>
            Open the matching repository file page from the raw file URL you are reading.
          </p>
        </article>

        <article class="feature-card">
          <div class="feature-icon" aria-hidden="true">02</div>
          <h3>Multiple Git hosts</h3>
          <p>
            Supports GitHub, GitHub Gist, GitLab, Gitea, Codeberg, and self-hosted GitLab or Gitea domains.
          </p>
        </article>

        <article class="feature-card">
          <div class="feature-icon" aria-hidden="true">03</div>
          <h3>Local and adjustable</h3>
          <p>
            Choose theme behavior, enable only the platforms you use, and hide files when needed.
          </p>
        </article>
      </div>
    </section>

    <section class="section" id="install">
      <div class="section-head">
        <h2>Install for Safari, package for the rest.</h2>
        <p>
          Safari users get the App Store version. Chromium and Firefox users can load
          the release packages manually.
        </p>
      </div>

      <div class="install-layout">
        <article class="install-card highlight">
          <h3>Safari</h3>
          <p>Install RawBack on iPhone, iPad, and Mac from the App Store.</p>
          <div class="actions">
            <a class="button" href="https://apps.apple.com/app/id6770844819" target="_blank" rel="noopener">
              <svg class="btn-icon" viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
                <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M15.97 4.17c.66-.81 1.11-1.93.99-3.06-.96.04-2.13.64-2.82 1.45-.6.7-1.13 1.84-.99 2.94.1 1.08 2.16 1.48 2.82.67z"/>
              </svg>
              <span>App Store</span>
            </a>
          </div>
        </article>

        <article class="install-card">
          <h3>Chrome, Edge, Brave, Firefox</h3>
          <p>Download the latest package from GitHub Releases.</p>
          <div class="install-steps">
            <div class="install-step">
              <span class="step-num">1</span>
              <span>Download the Chromium or Firefox zip.</span>
            </div>
            <div class="install-step">
              <span class="step-num">2</span>
              <span>Load the unpacked extension in your browser.</span>
            </div>
          </div>
          <div class="actions">
            <a class="button" href="https://github.com/tuot/RawBack/releases/latest" target="_blank" rel="noopener">
              <svg class="btn-icon" viewBox="0 0 98 96" width="18" height="18" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" clip-rule="evenodd" d="M48.854 0C21.839 0 0 22 0 49.217c0 21.756 13.993 40.172 33.4 46.68 2.447.453 3.337-.107 3.337-2.378 0-1.185-.04-4.304-.065-8.448-13.59 2.978-16.455-6.61-16.455-6.61-2.221-5.697-5.423-7.213-5.423-7.213-4.436-3.06.336-3 .336-3 4.908.348 7.493 5.093 7.493 5.093 4.359 7.537 11.442 5.358 14.228 4.096.444-3.187 1.706-5.36 3.1-6.6-10.849-1.25-22.256-5.476-22.256-24.39 0-5.389 1.905-9.8 5.03-13.257-.504-1.25-2.18-6.27.478-13.07 0 0 4.11-1.328 13.47 5.072 3.9-1.093 8.09-1.636 12.246-1.656 4.148.02 8.337.563 12.25 1.656 9.346-6.4 13.447-5.072 13.447-5.072 2.668 6.8 1.002 11.82.498 13.07 3.13 3.458 5.022 7.868 5.022 13.257 0 18.966-11.423 23.125-22.31 24.35 1.758 1.53 3.328 4.534 3.328 9.138 0 6.6-.06 11.91-.06 13.543 0 2.29.87 4.87 3.36 4.385C84.024 89.378 98 70.969 98 49.217 98 22 76.16 0 48.854 0z"/>
              </svg>
              <span>Open Releases</span>
            </a>
          </div>
        </article>
      </div>
    </section>
  </main>


</Layout>

<style>
  main {
    padding-top: 24px;
  }

  .shell {
    width: min(1180px, calc(100% - 32px));
    margin: 0 auto;
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(420px, 1.1fr);
    align-items: center;
    gap: clamp(32px, 6vw, 64px);
    min-height: calc(100vh - 118px);
    padding: 40px 0 64px;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin: 0 0 18px;
    color: var(--moss);
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .eyebrow::before {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: var(--clay);
    box-shadow: 0 0 0 5px var(--clay-soft);
    content: "";
  }

  h1,
  h2,
  h3 {
    margin: 0;
    color: var(--ink);
    font-family: "Source Serif 4", ui-serif, Georgia, Cambria, serif;
    letter-spacing: -0.01em;
  }

  h1 {
    max-width: 780px;
    font-size: clamp(3.2rem, 7vw, 5.8rem);
    line-height: 0.92;
    font-weight: 800;
  }

  h2 {
    font-size: clamp(1.8rem, 3.5vw, 3.2rem);
    line-height: 1.05;
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  h3 {
    font-size: 1.25rem;
    line-height: 1.3;
    font-weight: 700;
    font-family: "Outfit", sans-serif;
    letter-spacing: -0.01em;
  }

  .lead {
    max-width: 660px;
    margin: 24px 0 0;
    color: var(--ink-soft);
    font-size: clamp(1.05rem, 1.6vw, 1.25rem);
    line-height: 1.7;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 32px;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    min-height: 46px;
    padding: 0 22px;
    border: 1px solid var(--line);
    border-radius: 999px;
    color: var(--ink);
    background: rgba(255, 255, 255, 0.8);
    box-shadow: 0 4px 12px rgba(62, 90, 54, 0.05);
    font-family: "Outfit", sans-serif;
    font-weight: 700;
    font-size: 0.94rem;
    text-decoration: none;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    transition:
      transform 250ms cubic-bezier(0.34, 1.56, 0.64, 1),
      box-shadow 250ms cubic-bezier(0.34, 1.56, 0.64, 1),
      background-color 200ms ease,
      border-color 200ms ease,
      color 200ms ease;
  }

  .btn-icon {
    flex-shrink: 0;
    transition: transform 250ms cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .button:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 24px rgba(62, 90, 54, 0.12);
    background: rgba(255, 255, 255, 0.95);
    border-color: rgba(62, 90, 54, 0.25);
  }

  .button:hover .btn-icon {
    transform: scale(1.12);
  }

  .button:active {
    transform: translateY(0) scale(0.97);
    box-shadow: 0 4px 10px rgba(62, 90, 54, 0.08);
  }

  .button.primary {
    color: #fffdf8;
    border-color: rgba(255, 255, 255, 0.06);
    background: linear-gradient(135deg, #1f211c 0%, #0f100d 100%);
    box-shadow: 
      0 10px 25px rgba(28, 31, 24, 0.18), 
      inset 0 1px 0 rgba(255, 255, 255, 0.12);
  }

  .button.primary:hover {
    background: linear-gradient(135deg, #2b2d28 0%, #151713 100%);
    border-color: rgba(255, 255, 255, 0.12);
    box-shadow: 
      0 14px 30px rgba(28, 31, 24, 0.25), 
      0 0 16px var(--moss-glow), 
      inset 0 1px 0 rgba(255, 255, 255, 0.18);
  }

  .button.primary:active {
    box-shadow: 
      0 6px 15px rgba(28, 31, 24, 0.15), 
      inset 0 1px 0 rgba(255, 255, 255, 0.08);
  }

  .note {
    max-width: 560px;
    margin: 18px 0 0;
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.55;
  }

  .hero-art {
    position: relative;
    min-height: 520px;
  }

  .hero-art::before,
  .hero-art::after {
    position: absolute;
    border-radius: 55% 45% 42% 58% / 48% 42% 58% 52%;
    content: "";
    filter: blur(2px);
  }

  .hero-art::before {
    right: -6%;
    bottom: 7%;
    width: 66%;
    height: 46%;
    background: rgba(62, 90, 54, 0.08);
  }

  .hero-art::after {
    top: 0;
    left: 8%;
    width: 46%;
    height: 38%;
    background: rgba(166, 94, 50, 0.08);
  }

  .mac-frame,
  .phone-frame {
    position: absolute;
    overflow: hidden;
    border: 1px solid var(--line);
    background: var(--surface);
    box-shadow: var(--shadow-soft);
    transition: 
      transform 500ms cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 500ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .mac-frame {
    top: 34px;
    right: 0;
    z-index: 1;
    width: min(720px, 100%);
    border-radius: 14px;
    transform: rotate(1deg);
  }

  .mac-frame img {
    width: 100%;
    aspect-ratio: 3024 / 1732;
    object-fit: cover;
  }

  .phone-frame {
    left: 0;
    bottom: 0;
    z-index: 2;
    width: min(240px, 36vw);
    border-radius: 36px;
    transform: rotate(-3deg);
    border: 4px solid #1c1f18;
    box-shadow: 0 20px 45px rgba(28, 31, 24, 0.18);
  }

  .phone-frame img {
    width: 100%;
    aspect-ratio: 1320 / 2868;
    object-fit: cover;
  }

  .hero-art:hover .mac-frame {
    transform: rotate(0.5deg) translateY(-6px);
    box-shadow: 0 30px 75px rgba(28, 31, 24, 0.16);
  }

  .hero-art:hover .phone-frame {
    transform: rotate(-4deg) translateY(-10px) translateX(-2px);
    box-shadow: 0 30px 75px rgba(28, 31, 24, 0.26);
  }

  .context-strip {
    position: absolute;
    right: 30px;
    bottom: 48px;
    z-index: 3;
    display: grid;
    gap: 9px;
    width: min(380px, 54%);
    padding: 16px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: rgba(255, 255, 255, 0.88);
    box-shadow: var(--shadow-tight);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
  }

  .context-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    min-width: 0;
  }

  .context-label {
    color: var(--muted);
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .context-value {
    min-width: 0;
    color: var(--ink);
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.84rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .section {
    padding: 80px 0;
    border-top: 1px solid var(--line);
  }

  .section-head {
    display: grid;
    grid-template-columns: minmax(0, 0.76fr) minmax(280px, 0.44fr);
    gap: 28px;
    align-items: end;
    margin-bottom: 40px;
  }

  .section-head p {
    margin: 0;
    color: var(--ink-soft);
    font-size: 1.04rem;
    line-height: 1.65;
  }

  .flow {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 18px;
    align-items: stretch;
  }

  .flow-card,
  .feature-card,
  .install-card {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: rgba(255, 255, 255, 0.72);
    box-shadow: var(--shadow-soft);
    transition: 
      transform 350ms cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 350ms cubic-bezier(0.16, 1, 0.3, 1),
      border-color 300ms ease;
  }

  .flow-card:hover,
  .feature-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 36px rgba(62, 90, 54, 0.06), 0 4px 12px rgba(62, 90, 54, 0.02);
    border-color: rgba(62, 90, 54, 0.2);
  }

  .flow-card {
    min-width: 0;
    padding: 20px;
  }

  .flow-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 18px;
  }

  .host {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--ink-soft);
    font-weight: 700;
    font-size: 0.94rem;
  }

  .host-dot {
    width: 10px;
    height: 10px;
    border-radius: 999px;
    background: var(--moss);
  }

  .code-path {
    margin: 0;
    padding: 16px;
    border-radius: var(--radius-sm);
    color: #242921;
    background: rgba(235, 223, 200, 0.35);
    border: 1px solid rgba(62, 90, 54, 0.06);
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.88rem;
    line-height: 1.7;
    white-space: pre-wrap;
  }

  .flow-arrow {
    display: grid;
    place-items: center;
    width: 52px;
    color: #fffdf8;
    border-radius: 999px;
    background: var(--moss);
    font-weight: 800;
    box-shadow: 0 8px 20px rgba(62, 90, 54, 0.22);
  }

  .repo-banner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-top: 14px;
    padding: 12px 14px;
    border: 1px dashed rgba(62, 90, 54, 0.25);
    border-radius: var(--radius-sm);
    background: rgba(62, 90, 54, 0.04);
  }

  .repo-banner strong {
    display: block;
    font-size: 0.94rem;
  }

  .repo-banner span {
    color: var(--muted);
    font-size: 0.84rem;
  }

  .repo-pill {
    flex: 0 0 auto;
    padding: 8px 14px;
    border-radius: 999px;
    color: #fff;
    background: var(--moss);
    font-size: 0.84rem;
    font-weight: 800;
    transition: background-color 200ms ease, transform 200ms ease;
  }

  .repo-banner:hover .repo-pill {
    background: var(--moss-deep);
    transform: scale(1.03);
  }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 20px;
  }

  .feature-card {
    min-height: 178px;
    padding: 24px;
  }

  .feature-icon {
    display: grid;
    place-items: center;
    width: 38px;
    height: 38px;
    margin-bottom: 20px;
    border-radius: 999px;
    color: var(--moss);
    background: var(--moss-soft);
    font-family: "Outfit", sans-serif;
    font-weight: 800;
    font-size: 0.94rem;
    transition: 
      transform 300ms cubic-bezier(0.34, 1.56, 0.64, 1),
      background-color 300ms ease,
      color 300ms ease;
  }

  .feature-card:hover .feature-icon {
    transform: scale(1.1) rotate(6deg);
    background: var(--moss);
    color: #fffdf8;
  }

  .feature-card p,
  .install-card p {
    margin: 12px 0 0;
    color: var(--muted);
    line-height: 1.6;
    font-size: 0.92rem;
  }

  .install-layout {
    display: grid;
    grid-template-columns: minmax(0, 0.88fr) minmax(320px, 0.52fr);
    gap: 20px;
  }

  .install-card {
    padding: 28px;
  }

  .install-card:not(.highlight):hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 36px rgba(62, 90, 54, 0.06), 0 4px 12px rgba(62, 90, 54, 0.02);
    border-color: rgba(62, 90, 54, 0.2);
  }

  .install-card.highlight {
    position: relative;
    overflow: hidden;
    background: 
