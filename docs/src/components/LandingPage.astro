---
const { lang = "en" } = Astro.props;
const isZh = lang === "zh";

const copy = isZh
	? {
			heroTitle: "一键从 Raw 文件\n回到仓库页面。",
			heroLead:
				"打开 GitHub、GitLab、Gitea 等平台的 raw 文件时，RawBack 会自动显示返回入口。无需修改 URL，一次点击即可回到对应仓库上下文。",
			appStore: "App Store 安装",
			releases: "GitHub Releases",
			trust: ["本地运行", "无账号", "无广告", "无分析"],
			whyTitle: "为什么需要 RawBack？",
			whyLead: "查看 Raw 文件时，丢失了仓库的全部上下文",
			rawTitle: "Raw 页面",
			repoTitle: "仓库页面",
			rawProblems: [
				"看不到目录结构",
				"看不到提交历史",
				"看不到分支信息",
				"想看其他文件？只能手动改 URL",
			],
			repoBenefits: ["浏览目录", "查看历史记录", "切换分支", "访问其他文件"],
			whyFoot: "RawBack 将回到仓库的繁琐过程变成一键点击",
			traitsTitle: "简单、轻量、值得信赖",
			platformTitle: "支持所有主流 Git 平台",
			platformText: "在这些平台的 raw 页面都能使用，无需额外配置。",
			browserTitle: "支持所有主流浏览器",
			browserText: "提供 Safari 原生 App 以及 Chrome、Firefox、Brave、Edge 等扩展。",
			localTitle: "浏览器本地运行",
			localText: "所有转换都在浏览器本地完成。无账号、无广告、无追踪。",
			focusTitle: "只做一件事",
			focusText: "专注于帮你回到仓库。不修改页面，不能影响阅读体验。",
			localTags: ["无账号", "无广告", "无追踪"],
			focusTags: ["轻量", "快速", "简洁"],
			installTitle: "安装只需要一分钟",
			installLead: "选择你的浏览器开始使用",
			safariTitle: "Safari",
			safariText: "在 iPhone、iPad 和 Mac 上通过 App Store 安装 RawBack。",
			safariCta: "App Store",
			chromeTitle: "Chrome、Edge、Brave、Firefox",
			chromeText: "从 GitHub Release 下载最新浏览器扩展包。",
			chromeStep1: "下载 Chromium 或 Firefox zip。",
			chromeStep2: "在浏览器中加载解压后的扩展。",
			releasesCta: "打开 Release",
		}
	: {
			heroTitle: "One click\nfrom raw files\nback to the repo.",
			heroLead:
				"When you open raw files on GitHub, GitLab, Gitea, and more, RawBack automatically adds a shortcut back. No manual URL editing required, one click restores the repository context.",
			appStore: "App Store",
			releases: "GitHub Releases",
			trust: ["Locally", "No accounts", "No ads", "No tracking"],
			whyTitle: "Why RawBack?",
			whyLead: "Raw pages are useful, but they strip away all repository context.",
			rawTitle: "Raw Page",
			repoTitle: "Repository Page",
			rawProblems: [
				"No directory structure",
				"No commit history",
				"No branch context",
				"Want other files? You must edit the URL manually",
			],
			repoBenefits: [
				"Browse directory structure",
				"View commit history",
				"Switch branches",
				"Access other files easily",
			],
			whyFoot: "RawBack turns that detour into a single click.",
			traitsTitle: "Simple, Lightweight, and Trustworthy",
			platformTitle: "Supports All Major Git Platforms",
			platformText:
				"Works seamlessly on raw pages across the platforms you already use. Zero setup required.",
			browserTitle: "Supports All Major Browsers",
			browserText:
				"Available as a native Safari app, plus extensions for Chrome, Firefox, Edge, Brave, and more.",
			localTitle: "Runs Locally in Your Browser",
			localText: "All URL conversions happen locally in your browser. No accounts, ads, or tracking.",
			focusTitle: "Does One Thing",
			focusText:
				"Focused entirely on getting you back to the repository. It never alters the page or disrupts your reading.",
			localTags: ["No Account", "No Ads", "No Tracking"],
			focusTags: ["Lightweight", "Fast", "Clean"],
			installTitle: "Install in Under a Minute",
			installLead: "Choose your browser to get started",
			safariTitle: "Safari",
			safariText: "Install RawBack from the App Store on iPhone, iPad, and Mac.",
			safariCta: "App Store",
			chromeTitle: "Chrome, Edge, Brave, Firefox",
			chromeText: "Download the latest extension package from GitHub Releases.",
			chromeStep1: "Download the Chromium or Firefox zip file.",
			chromeStep2: "Load the unpacked extension in your browser.",
			releasesCta: "Open Releases",
		};

const base = import.meta.env.BASE_URL;
const iconBase = `${base}/assets/third-party-icons`;

const platforms = [
	{ name: "GitHub", tone: "platform-black", logo: "github" },
	{ name: "GitLab", tone: "platform-orange", logo: "gitlab" },
	{ name: "Gitea", tone: "platform-green", logo: "gitea" },
	{ name: "Codeberg", tone: "platform-blue", logo: "codeberg" },
];

const browsers = [
	{ name: "Chrome", tone: "browser-gray", logo: "chrome" },
	{ name: "Safari", tone: "browser-blue", logo: "safari" },
	{ name: "Firefox", tone: "browser-orange", logo: "firefox" },
	{ name: "Edge", tone: "browser-blue", logo: "edge" },
	{ name: "Brave", tone: "browser-orange", logo: "brave" },
];

const repoItems = [
	{ name: ".github", type: "folder" },
	{ name: "assets", type: "folder" },
	{ name: "src", type: "folder" },
	{ name: ".gitignore", type: "file" },
	{ name: "README.md", type: "file" },
];
---

<main class="landing">
	<section class="hero" id="top">
		<div class="hero-copy">
			<h1>{copy.heroTitle}</h1>
			<p class="lead">{copy.heroLead}</p>
			<div class="hero-actions" aria-label={isZh ? "安装选项" : "Installation options"}>
				<a
					class="button button-primary"
					href="https://apps.apple.com/app/id6770844819"
					target="_blank"
					rel="noopener"
				>
					<img
						class="button-icon"
						src={`${iconBase}/apple.svg`}
						alt=""
						aria-hidden="true"
						decoding="async"
					/>
					<span>{copy.appStore}</span>
				</a>
				<a
					class="button"
					href="https://github.com/tuot/RawBack/releases/latest"
					target="_blank"
					rel="noopener"
				>
					<img class="button-icon" src={`${iconBase}/github.svg`} alt="" aria-hidden="true" />
					<span>{copy.releases}</span>
				</a>
			</div>
			<ul class="trust-list" aria-label={isZh ? "产品承诺" : "Key benefits"}>
				{
					copy.trust.map((item) => (
						<li>
							<span aria-hidden="true">✓</span>
							{item}
						</li>
					))
				}
			</ul>
		</div>

		<div
			class="hero-visual"
			aria-label={isZh
				? "RawBack 从 raw 文件返回仓库的界面示意"
				: "Preview of RawBack returning to the repository from a raw file"}
		>
			<img
				src={`${base}/assets/hero.png`}
				alt=""
				width="1265"
				height="870"
				decoding="async"
				fetchpriority="high"
			/>
		</div>
	</section>

	<section class="section why" id="features">
		<div class="section-heading">
			<h2>{copy.whyTitle}</h2>
			<p>{copy.whyLead}</p>
		</div>

		<div class="compare-row">
			<article class="compare-card">
				<div class="compare-text">
					<div class="card-title">
						<h3>{copy.rawTitle}</h3>
						<svg class="mood-icon sad" viewBox="0 0 28 28" aria-hidden="true" focusable="false">
							<circle cx="14" cy="14" r="11.5"></circle>
							<path d="M9.5 11h.01M18.5 11h.01M9.8 20c1-1.5 2.4-2.3 4.2-2.3s3.2.8 4.2 2.3"></path>
						</svg>
					</div>
					<ul class="problem-list">
						{
							copy.rawProblems.map((item) => (
								<li>
									<svg class="list-icon" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
										<path d="M4 4l8 8M12 4l-8 8"></path>
									</svg>
									<span>{item}</span>
								</li>
							))
						}
					</ul>
				</div>
				<div class="mini-browser raw-mini">
					<div class="mini-bar">
						<span></span><span></span><span></span><em
							>raw.githubusercontent.com/...</em>
					</div>
					<div class="code-sample" aria-hidden="true">
						<p><span>1</span><code><b>def</b> hello():</code></p>
						<p><span>2</span><code>    <b>print</b>("hello world")</code></p>
					</div>
				</div>
			</article>

			<div class="round-arrow" aria-hidden="true">
				<svg viewBox="0 0 28 28" focusable="false">
					<path d="M6 14h14M15 8l6 6-6 6"></path>
				</svg>
			</div>

			<article class="compare-card">
				<div class="compare-text">
					<div class="card-title">
						<h3>{copy.repoTitle}</h3>
						<svg class="mood-icon happy" viewBox="0 0 28 28" aria-hidden="true" focusable="false">
							<circle cx="14" cy="14" r="11.5"></circle>
							<path d="M9.5 11h.01M18.5 11h.01M9.6 17.4c1 1.8 2.5 2.7 4.4 2.7s3.4-.9 4.4-2.7"></path>
						</svg>
					</div>
					<ul class="benefit-list">
						{
							copy.repoBenefits.map((item) => (
								<li>
									<svg class="list-icon" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
										<path d="m3 8.5 3.2 3.2L13 4.8"></path>
									</svg>
									<span>{item}</span>
								</li>
							))
						}
					</ul>
				</div>
				<div class="mini-browser repo-mini">
					<div class="mini-bar">
						<span></span><span></span><span></span><em>github.com/tuot/RawBack</em>
					</div>
					<div class="folder-list">
						<strong>
							<svg viewBox="0 0 16 16" aria-hidden="true" focusable="false">
								<path d="M2.5 4.5h11v9h-11zM2.5 4.5l2-2h9v11"></path>
							</svg>
							RawBack
						</strong>
						{
							repoItems.map((item) => (
								<span>
									{item.type === "folder" ? (
										<svg viewBox="0 0 16 16" aria-hidden="true" focusable="false">
											<path d="M1.8 4.5h4.7l1.2 1.4h6.5v6.8H1.8z"></path>
										</svg>
									) : (
										<svg viewBox="0 0 16 16" aria-hidden="true" focusable="false">
											<path d="M4 2.3h5.4L12 5v8.7H4z"></path>
											<path d="M9.3 2.4V5h2.6"></path>
										</svg>
									)}
									{item.name}
								</span>
							))
						}
					</div>
				</div>
			</article>
		</div>
		<p class="center-note">{copy.whyFoot}</p>
	</section>

	<section class="section traits" id="traits">
		<h2>{copy.traitsTitle}</h2>
		<div class="trait-grid">
			<article class="trait-card">
				<svg class="trait-icon" viewBox="0 0 48 48" aria-hidden="true" focusable="false">
					<circle cx="24" cy="24" r="17"></circle>
					<path
						d="M7 24h34M24 7c5 5.6 7.4 11.2 7.4 17S29 35.4 24 41M24 7c-5 5.6-7.4 11.2-7.4 17S19 35.4 24 41"
					></path>
				</svg>
				<h3>{copy.platformTitle}</h3>
				<p>{copy.platformText}</p>
				<div class="platforms">
					{
						platforms.map((platform) => (
							<span class={`platform ${platform.tone}`}>
								{platform.logo !== "self-hosted" && (
									<img
										src={`${iconBase}/${platform.logo}.svg`}
										alt=""
										aria-hidden="true"
										loading="lazy"
										decoding="async"
									/>
								)}
								{platform.name}
							</span>
						))
					}
				</div>
			</article>
			<article class="trait-card">
				<svg class="trait-icon" viewBox="0 0 48 48" aria-hidden="true" focusable="false">
					<rect x="6" y="8" width="36" height="32" rx="4"></rect>
					<path d="M6 18h36M12 13h.01M17 13h.01M22 13h.01"></path>
				</svg>
				<h3>{copy.browserTitle}</h3>
				<p>{copy.browserText}</p>
				<div class="platforms">
					{
						browsers.map((browser) => (
							<span class={`platform ${browser.tone}`}>
								<img
									src={`${iconBase}/${browser.logo}.svg`}
									alt=""
									aria-hidden="true"
									loading="lazy"
									decoding="async"
								/>
								{browser.name}
							</span>
						))
					}
				</div>
			</article>
			<article class="trait-card">
				<svg class="trait-icon" viewBox="0 0 48 48" aria-hidden="true" focusable="false">
					<path d="M24 6 38 11v10.8c0 9.2-5.6 16.4-14 20.2-8.4-3.8-14-11-14-20.2V11l14-5Z"
					></path>
					<path d="m17 24 4.6 4.6L31.8 18"></path>
				</svg>
				<h3>{copy.localTitle}</h3>
				<p>{copy.localText}</p>
				<div class="tag-row">
					{copy.localTags.map((tag) => <span>{tag}</span>)}
				</div>
			</article>
			<article class="trait-card">
				<svg
					class="trait-icon bolt-icon"
					viewBox="0 0 48 48"
					aria-hidden="true"
					focusable="false"
				>
					<path d="M27 4 11 28h12l-2 16 16-24H25L27 4Z"></path>
				</svg>
				<h3>{copy.focusTitle}</h3>
				<p>{copy.focusText}</p>
				<div class="tag-row">
					{copy.focusTags.map((tag) => <span>{tag}</span>)}
				</div>
			</article>
		</div>
	</section>

	<section class="section install" id="install">
		<div class="section-heading">
			<h2>{copy.installTitle}</h2>
			<p>{copy.installLead}</p>
		</div>
		<div class="install-grid">
			<article class="install-card safari-card">
				<div class="card-content-wrapper">
					<img class="safari-big-logo" src={`${iconBase}/safari.svg`} alt="Safari" aria-hidden="true" />
					<div class="card-content">
						<h3>{copy.safariTitle}</h3>
						<p>{copy.safariText}</p>
					</div>
				</div>
				<a
					class="button-safari"
					href="https://apps.apple.com/app/id6770844819"
					target="_blank"
					rel="noopener"
				>
					<svg
						class="button-icon"
						viewBox="0 0 24 24"
						aria-hidden="true"
						focusable="false"
					>
						<path
							d="M16.82 12.58c-.03-2.7 2.24-4 2.34-4.06-1.29-1.86-3.23-2.12-3.9-2.15-1.64-.17-3.23.98-4.06.98-.85 0-2.13-.96-3.52-.93-1.79.03-3.46 1.06-4.38 2.68-1.89 3.28-.48 8.1 1.33 10.75.9 1.3 1.95 2.75 3.34 2.7 1.35-.06 1.86-.86 3.49-.86 1.61 0 2.09.86 3.5.83 1.46-.03 2.37-1.3 3.24-2.61 1.04-1.49 1.46-2.96 1.48-3.03-.03-.01-2.83-1.08-2.86-4.3Z"
							fill="currentColor"
						></path>
						<path
							d="M14.2 4.64c.73-.9 1.22-2.12 1.09-3.35-1.05.05-2.36.72-3.12 1.6-.68.78-1.29 2.05-1.13 3.23 1.19.1 2.4-.6 3.16-1.48Z"
							fill="currentColor"
						></path>
					</svg>
					<span>{copy.safariCta}</span>
				</a>
			</article>

			<article class="install-card chrome-card">
				<div class="card-content">
					<div class="browser-icons-row">
						<img src={`${iconBase}/chrome.svg`} alt="Chrome" aria-hidden="true" />
						<img src={`${iconBase}/edge.svg`} alt="Edge" aria-hidden="true" />
						<img src={`${iconBase}/brave.svg`} alt="Brave" aria-hidden="true" />
						<img src={`${iconBase}/firefox.svg`} alt="Firefox" aria-hidden="true" />
					</div>
					<h3>{copy.chromeTitle}</h3>
					<p>{copy.chromeText}</p>
					<ol class="step-list">
						<li>
							<span class="step-num">1</span>
							<span class="step-text">{copy.chromeStep1}</span>
						</li>
						<li>
							<span class="step-num">2</span>
							<span class="step-text">{copy.chromeStep2}</span>
						</li>
					</ol>
				</div>
				<a
					class="button-chrome"
					href="https://github.com/tuot/RawBack/releases/latest"
					target="_blank"
					rel="noopener"
				>
					<img class="button-icon" src={`${iconBase}/github.svg`} alt="" aria-hidden="true" />
					<span>{copy.releasesCta}</span>
				</a>
			</article>
		</div>
	</section>
</main>

<style>
	.landing {
		width: min(1120px, calc(100% - 56px));
		margin: 0 auto;
	}

	.hero {
		display: grid;
		grid-template-columns: 430px minmax(0, 1fr);
		align-items: center;
		gap: 62px;
		min-height: 560px;
		padding: 54px 0 52px;
	}

	.hero-copy h1 {
		margin: 0;
		color: #111315;
		font-size: 52px;
		line-height: 1.18;
		font-weight: 800;
		letter-spacing: 0;
		white-space: pre-line;
	}

	.lead {
		margin: 26px 0 0;
		color: #40464d;
		font-size: 17px;
		line-height: 1.78;
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 20px;
		margin-top: 32px;
	}

	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 10px;
		min-width: 190px;
		min-height: 52px;
		padding: 0 22px;
		border: 1px solid #d8dde2;
		border-radius: 9px;
		color: #141719;
		background: #fff;
		box-shadow: 0 8px 20px rgba(17, 24, 39, 0.04);
		font-size: 16px;
		font-weight: 700;
		text-decoration: none;
	}

	.button:hover,
	.install-card a:hover {
		transform: translateY(-1px);
	}

	.button-primary {
		border-color: #2fa660;
		color: #fff;
		background: #2ea35d;
		box-shadow: 0 12px 24px rgba(33, 138, 78, 0.22);
	}

	.button-icon {
		width: 18px;
		height: 18px;
		flex: 0 0 auto;
		object-fit: contain;
	}

	.button-primary .button-icon {
		filter: brightness(0) invert(1);
	}

	.trust-list {
		display: flex;
		flex-wrap: wrap;
		gap: 22px;
		margin: 34px 0 0;
		padding: 0;
		list-style: none;
		color: #1c2b22;
		font-size: 14px;
		font-weight: 600;
	}

	.trust-list li {
		display: inline-flex;
		align-items: center;
		gap: 7px;
	}

	.trust-list span {
		display: inline-grid;
		place-items: center;
		width: 16px;
		height: 16px;
		border: 1px solid #2ea35d;
		border-radius: 50%;
		color: #2ea35d;
		font-size: 11px;
	}

	.hero-visual {
		width: min(720px, 100%);
		margin-right: -42px;
	}

	.hero-visual img {
		display: block;
		width: 100%;
		height: auto;
		filter: drop-shadow(0 24px 36px rgba(17, 24, 39, 0.08))
			drop-shadow(0 8px 18px rgba(17, 24, 39, 0.06));
	}

	.section {
		padding: 42px 0;
		border-top: 1px solid #dde1e5;
	}

	.section-heading,
	.traits h2,
	.preview h2 {
		text-align: center;
	}

	.section h2 {
		margin: 0;
		color: #111315;
		font-size: 30px;
		line-height: 1.25;
		font-weight: 800;
		letter-spacing: 0;
	}

	.section-heading p {
		margin: 12px 0 0;
		color: #3f464d;
		font-size: 16px;
	}

	.compare-row {
		display: grid;
		grid-template-columns: 1fr 50px 1fr;
		align-items: stretch;
		gap: 18px;
		margin-top: 28px;
	}

	.compare-card {
		display: grid;
		grid-template-columns: minmax(172px, 0.78fr) minmax(240px, 1fr);
		align-items: stretch;
		gap: 22px;
		min-height: 216px;
		height: 100%;
		padding: 22px 22px 22px 24px;
		border: 1px solid #d8dde2;
		border-radius: 8px;
		background: #fff;
	}

	.compare-text {
		display: flex;
		min-width: 0;
		flex-direction: column;
		justify-content: flex-start;
	}

	.card-title {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 10px;
	}

	.card-title h3,
	.trait-card h3,
	.install-card h3 {
		margin: 0;
		color: #121518;
		font-size: 18px;
		line-height: 1.35;
		font-weight: 800;
		letter-spacing: 0;
	}

	.mood-icon {
		width: 24px;
		height: 24px;
		flex: 0 0 auto;
		fill: none;
		stroke: currentColor;
		stroke-linecap: round;
